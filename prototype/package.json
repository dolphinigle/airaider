{
  "name": "airaider-prototype",
  "version": "0.0.0",
  "private": true,
  "description": "Console prototype for airaider — proves the AI scenario engine end-to-end. Eventual game will have a card-drag GUI; this is for design iteration and self-testable narrative resolution.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "scenario": "tsx src/cli.ts",
    "day": "tsx src/cliDay.ts",
    "recruit": "tsx src/cliRecruit.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "openai": "^4.68.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
